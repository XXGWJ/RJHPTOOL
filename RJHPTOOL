      return    try:        file_dir = os.path.dirname(rjh_file)        original_dir = os.getcwd()        os.chdir(file_dir)        subprocess.run(["chmod", "+x", "./RJH"], check=True, capture_output=True)        subprocess.call(["./RJH"])        os.chdir(original_dir)    except Exception as e:        print_centered_box("❌ RJH启动失败", [f"错误信息: {str(e)}"], "red")        console.input(f"\n[blue]按回车键继续...[/blue]")def wait_with_extend(initial_seconds=0.45, extend_seconds=10):    """带倒计时+延长功能：默认0.45秒自动返回，按←延长10秒，按回车立即返回"""    old_settings = termios.tcgetattr(sys.stdin)    try:        tty.setraw(sys.stdin.fileno())        # 显示初始提示        print(f"\n[cyan]操作：按回车立即返回 | 按←延长{extend_seconds}秒 | 剩余 {initial_seconds} 秒自动返回...[/cyan]", end="", flush=True)                start_time = time.time()        total_seconds = initial_seconds        last_print_time = time.time()                while True:            elapsed = time.time() - start_time            remaining = round(total_seconds - elapsed, 2)                        if remaining <= 0:                print("\r[cyan]操作：按回车立即返回 | 按←延长时间 | 剩余 0.0 秒，即将返回...[/cyan]", end="", flush=True)                time.sleep(0.1)                break                        # 0.05秒刷新一次倒计时            if time.time() - last_print_time >= 0.05:                print(f"\r[cyan]操作：按回车立即返回 | 按←延长{extend_seconds}秒 | 剩余 {remaining:.2f} 秒自动返回...[/cyan]", end="", flush=True)                last_print_time = time.time()                        if sys.stdin in select.select([sys.stdin], [], [], 0.02)[0]:                # 读取一个字符，检查是否是ESC                first_char = sys.stdin.read(1)                                if first_char in ['\r', '\n']:  # 回车键                    print("\n[green]已确认，立即返回主菜单...[/green]")                    break                elif first_char == '\x1b':  # ESC字符，可能是方向键                    # 继续读取2个字符                    next_chars = sys.stdin.read(2)                    if next_chars in ['[D', 'OD']:  # ←箭头                        total_seconds += extend_seconds                        remaining = round(total_seconds - elapsed, 2)                        print(f"\r[yellow]已延长{extend_seconds}秒！当前剩余 {remaining:.2f} 秒...[/yellow]", end="", flush=True)                        last_print_time = time.time()                print()    finally:        termios.tcsetattr(sys.stdin, termios.TCSADRAIN, old_settings)def main():    """主函数 - 按需求调整返回时间"""    tool = UE4PakTool()        while True:        show_welcome()        show_main_menu()        print()        choice = console.input(Text("选择一个选项 (1-5): ", style="bold cyan")).strip()                if choice == "1":            os.system('clear' if os.name != 'nt' else 'cls')            print_centered_box("🚀 解包PAK文件", [                "",                "正在获取PAK文件列表...",                "请稍候...",                ""            ], "cyan")            pak_files = tool.get_pak_files(tool.BASE_DIR)            selected_pak = tool.select_pak_file(pak_files)            if selected_pak:                if selected_pak == "all":                    print_centered_box("⚡ 批量解包所有PAK文件", [                        "",                        "开始批量解包所有PAK文件...",                        "这可能需要一些时间，请耐心等待",                        ""                    ], "yellow")                    unpack_result = tool.unpack_pak(selected_pak)                else:                    unpack_result = tool.unpack_pak(selected_pak)                                if unpack_result:                    if selected_pak == "all":                        print_centered_box("✅ 批量解包完成", [                            f"已批量解包所有PAK文件",                            f"每个PAK文件的解包数据保存在对应的文件夹中",                            f"",                            f"下次打包时将会自动调用对应的解包目录",                            f"修改文件请放在对应的Edited_重新包装子文件夹中"                        ], "green")                    else:                        unpack_dir = tool.get_unpack_dir