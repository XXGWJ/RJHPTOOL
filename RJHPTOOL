import osimport structimport zlibimport hashlibfrom pathlib import Pathimport sysimport shutilimport timeimport jsonimport iofrom collections import defaultdictclass UE4PakTool:    def __init__(self):        self.ENCRYPT = 0        self.ENTRIES_DATA = {}  # 存储压缩信息 {文件路径: 压缩信息}        self.FILE_NAME_TO_PATHS = defaultdict(list)  # 文件名到完整路径的映射        self.BASE_PATH = ""        self.TOC_DATA = None  # 存储TOC数据        self.CURRENT_PAK_NAME = ""  # 当前操作的PAK文件名                # 定义路径（仅保留核心目录）        self.BASE_DIR = "/data/user/0/com.termux/files/home/RJToolHP/Original_PAK"        self.UNPACK_BASE_DIR = "/data/user/0/com.termux/files/home/RJToolHP/Unpack_Files"        self.PACK_BASE_DIR = "/data/user/0/com.termux/files/home/RJToolHP/Edited_重新包装"        self.PACK_FINISHED_DIR = "/data/user/0/com.termux/files/home/RJToolHP/Repack_PAK"                # 自动创建所需目录        Path(self.UNPACK_BASE_DIR).mkdir(parents=True, exist_ok=True)        Path(self.PACK_BASE_DIR).mkdir(parents=True, exist_ok=True)        Path(self.PACK_FINISHED_DIR).mkdir(parents=True, exist_ok=True)        def get_unpack_dir_for_pak(self, pak_file):        """根据PAK文件名获取对应的解包目录"""        pak_name = pak_file.stem  # 去掉扩展名        unpack_dir = Path(self.UNPACK_BASE_DIR) / pak_name        return unpack_dir        def get_pack_dir_for_pak(self, pak_file):        """根据PAK文件名获取对应的打包目录"""        pak_name = pak_file.stem  # 去掉扩展名        pack_dir = Path(self.PACK_BASE_DIR) / pak_name        return pack_dir        def get_all_unpack_dirs(self):        """获取所有已解包的PAK文件夹"""        unpack_dirs = []        if Path(self.UNPACK_BASE_DIR).exists():            for item in Path(self.UNPACK_BASE_DIR).iterdir():                if item.is_dir():                    unpack_dirs.append(item)        return unpack_dirs        def get_pak_files(self, directory):        """获取目录下所有的.pak文件"""        pak_dir = Path(directory)        if not pak_dir.exists():            print(f"目录不存在: {directory}")            return []                pak_files = list(pak_dir.glob("*.pak"))        return pak_files        def select_pak_file(self, pak_files):        """让用户选择要操作的.pak文件，输入0返回，输入all批量处理"""        if not pak_files:            print("未找到.pak文件")            return None                    print(f"\n0: 返回主菜单")        print(f"all: 解包所有PAK文件")        print("-" * 50)        print("可用的.pak文件:")                for i, pak_file in enumerate(pak_files, 1):            size_mb = pak_file.stat().st_size / 1024 / 1024                        # 检查是否有对应的解包文件夹            unpack_dir = self.get_unpack_dir_for_pak(pak_file)            unpack_status = "✅ 已解包" if unpack_dir.exists() else "❌ 未解包"                        print(f"{i}: {pak_file.name} ({size_mb:.2f} MB) - {unpack_status}")                while True:            try:                choice = input("\n请选择要操作的文件编号 (或输入'all'): ").strip().lower()                if choice == "0":                    return None                elif choice == "all":                    return "all"  # 特殊标记，表示批量处理                                choice = int(choice)                if 1 <= choice <= len(pak_files):                    selected_pak = pak_files[choice - 1]                    self.CURRENT_PAK_NAME = selected_pak.stem  # 保存当前PAK文件名                    return selected_pak                else:                    print(f"无效的选择，请输入 0-{len(pak_files)} 之间的数字，或输入'all'")            except ValueError:                print("请输入有效的数字或'all'")        def select_unpack_dir_to_clear(self):        """选择要清空的解包文件夹"""        unpack_dirs = self.get_all_unpack_dirs()                if not unpack_dirs:            print("没有找到已解包的PAK文件夹")            return None                print(f"\n0: 返回主菜单")        print(f"all: 清空所有解包文件夹")        print("-" * 50)        print("已解包的PAK文件夹:")                for i, unpack_dir in enumerate(unpack_dirs, 1):            # 计算文件夹大小            total_size = 0            for file_path in unpack_dir.rglob('*'):                if file_path.is_file():                    total_size += file_path.stat().st_size                        size_mb = total_size / 1024 / 1024            file_count = sum(1 for _ in unpack_dir.rglob('*') if _.is_file())            print(f"{i}: {unpack_dir.name} ({size_mb:.2f} MB, {file_count} 个文件)")                while True:            try:                choice = input("\n请选择要清空的文件夹编号 (或输入'all'): ").strip().lower()                if choice == "0":                    return None                elif choice == "all":                    return "all"  # 特殊标记，表示清空所有                                choice = int(choice)                if 1 <= choice <= len(unpack_dirs):                    return unpack_dirs[choice - 1]                else:                    print(f"无效的选择，请输入 0-{len(unpack_dirs)} 之间的数字，或输入'all'")            except ValueError:                print("请输入有效的数字或'all'")        def clear_unpack_dir(self, unpack_dir):        """清空指定的解包目录"""        if not unpack_dir.exists():            print(f"目录不存在: {unpack_dir}")            return False                try:            # 计算要删除的文件数量            file_count = sum(1 for _ in unpack_dir.rglob('*') if _.is_file())            total_size = 0            for file_path in unpack_dir.rglob('*'):                if file_path.is_file():                    total_size += file_path.stat().st_size                        size_mb = total_size / 1024 / 1024                        # 确认删除            print(f"\n⚠️  将要清空: {unpack_dir.name}")            print(f"   文件数量: {file_count} 个")            print(f"   总大小: {size_mb:.2f} MB")                        confirm = input("确认清空此文件夹? (y/n): ").strip().lower()            if confirm != 'y':                print("取消清空操作")                return False                        # 清空目录            shutil.rmtree(unpack_dir)            print(f"✅ 已清空解包目录: {unpack_dir}")            return True                    except Exception as e:            print(f"❌ 清空解包目录失败: {e}")            return False        def clear_all_unpack_dirs(self):        """清空所有解包目录"""        unpack_dirs = self.get_all_unpack_dirs()                if not unpack_dirs:            print("没有找到已解包的PAK文件夹")            return False                # 统计总信息        total_files = 0        total_size = 0        for unpack_dir in unpack_dirs:            for file_path in unpack_dir.rglob('*'):                if file_path.is_file():                    total_files += 1                    total_size += file_path.stat().st_size                total_size_mb = total_size / 1024 / 1024                print(f"\n⚠️  将要清空所有解包文件夹")        print(f"   文件夹数量: {len(unpack_dirs)} 个")        print(f"   总文件数量: {total_files} 个")        print(f"   总大小: {total_size_mb:.2f} MB")                confirm = input("确认清空所有文件夹? (y/n): ").strip().lower()        if confirm != 'y':            print("取消清空操作")            return False                success_count = 0        for unpack_dir in unpack_dirs:            try:                shutil.rmtree(unpack_dir)                print(f"✅ 已清空: {unpack_dir.name}")                success_count += 1            except Exception as e:                print(f"❌ 清空失败 {unpack_dir.name}: {e}")                print(f"\n清空完成: {success_count}/{len(unpack_dirs)} 个文件夹")        return success_count > 0        def clear_memory_data(self):        """清空内存数据"""        self.ENTRIES_DATA.clear()        self.FILE_NAME_TO_PATHS.clear()        self.TOC_DATA = None        self.CURRENT_PAK_NAME = ""        print("✅ 已清空内存中的压缩信息")        return True        def clear_all_temp_data(self):        """清空所有临时数据（内存和打包目录）"""        print("开始清空所有临时数据...")                # 清空重新包装目录中的临时编辑文件        pack_path = Path(self.PACK_BASE_DIR)        if pack_path.exists():            try:                for item in pack_path.iterdir():                    if item.is_file() and item.suffix == '.pak':                        item.unlink()                        print(f"已删除临时编辑文件: {item.name}")            except Exception as e:                print(f"清空临时编辑文件失败: {e}")                # 清空内存数据        self.clear_memory_data()        return True        def unpack_all_pak_files(self):        """批量解包所有PAK文件"""        pak_files = self.get_pak_files(self.BASE_DIR)                if not pak_files:            print("没有找到PAK文件")            return False                print(f"找到 {len(pak_files)} 个PAK文件，开始批量解包...")        print("=" * 50)                success_count = 0        failed_count = 0                for i, pak_file in enumerate(pak_files, 1):            print(f"\n[{i}/{len(pak_files)}] 处理: {pak_file.name}")                        # 检查是否已解包            unpack_dir = self.get_unpack_dir_for_pak(pak_file)            if unpack_dir.exists():                print(f"  ⚠️  已解包过，跳过: {pak_file.name}")                continue                        # 解包单个文件            if self.unpack_single_pak(pak_file):                success_count += 1                print(f"  ✅ 解包成功: {pak_file.name}")            else:                failed_count += 1                print(f"  ❌ 解包失败: {pak_file.name}")                        # 清理内存数据，避免影响下一个文件            self.clear_memory_data()                print("\n" + "=" * 50)        print(f"批量解包完成!")        print(f"成功: {success_count} 个文件")        print(f"失败: {failed_count} 个文件")                return success_count > 0        def unpack_single_pak(self, pak_file):        """解包单个PAK文件（内部方法）"""        print(f"开始解包: {pak_file.name}")                # 获取对应的解包目录        unpack_dir = self.get_unpack_dir_for_pak(pak_file)        print(f"解包输出目录: {unpack_dir}")                # 如果目录已存在，跳过（批量处理时已经检查过）                # 创建解包目录        unpack_dir.mkdir(parents=True, exist_ok=True)                # 创建对应的打包目录        pack_dir = self.get_pack_dir_for_pak(pak_file)        pack_dir.mkdir(parents=True, exist_ok=True)        print(f"创建打包目录: {pack_dir}")                # 清空内存数据        self.ENTRIES_DATA.clear()        self.FILE_NAME_TO_PATHS.clear()        self.CURRENT_PAK_NAME = pak_file.stem                start_time = time.time()        try:            with open(pak_file, 'rb') as f:                magic_offset = self.find_magic_offset(f)                print(f"魔法字节偏移: {magic_offset}")                f.seek(magic_offset)                                base_path = self.get_base_path(f)                print(f"基础路径: {base_path}")                                files_data = f.read(4)                if len(files_data) < 4:                    print("错误: 无法读取文件数量")                    return False                                file_count = struct.unpack('<I', files_data)[0]                print(f"文件条目数量: {file_count:,}")                                if file_count > 1000000:                    print("警告: 文件数量异常，可能是加密或格式错误")                    return False                                print("正在读取文件条目...")                entries = []                for i in range(file_count):                    entry = self.read_file_entry(f, i)                    if entry:                        entries.append(entry)                                        if (i + 1) % 10000 == 0:                        print(f"  已读取 {i + 1:,} / {file_count:,} 条目")                                print(f"成功读取 {len(entries):,} 个文件条目")                                entries_data = f.read(8)                if len(entries_data) < 8:                    print("错误: 无法读取目录结构")                    return False                                entries_count = struct.unpack('<Q', entries_data)[0]                print(f"目录条目数量: {entries_count:,}")                                if self.ENCRYPT:                    dummy_byte = f.read(1)                                toc_offset = f.tell()                file_size = os.path.getsize(pak_file)                toc_size = file_size - toc_offset                print(f"TOC偏移: {toc_offset:,}, TOC大小: {toc_size:,} 字节")                                f.seek(toc_offset)                self.TOC_DATA = f.read(toc_size)                                return self.process_directory_structure(entries, unpack_dir, base_path, f)                        except Exception as e:            print(f"解包出错: {e}")            import traceback            traceback.print_exc()            return False        def unpack_pak(self, pak_file):        """解包PAK文件到对应的文件夹（外部调用接口）"""        if pak_file == "all":            return self.unpack_all_pak_files()        else:            return self.unpack_single_pak(pak_file)        def read_string(self, file_obj, length, encoding='utf-8'):        """读取指定长度的字符串"""        data = file_obj.read(length)        try:            return data.decode(encoding).rstrip('\x00')        except:            return data.decode(encoding, errors='ignore').rstrip('\x00')  # 增加容错        def read_unicode_string(self, file_obj, length):        """读取Unicode字符串"""        data = file_obj.read(length * 2)        try:            return data.decode('utf-16-le').rstrip('\x00')        except:            return data.decode('utf-16-le', errors='ignore').rstrip('\x00')  # 增加容错        def get_base_path(self, file_obj):        """获取PAK文件的基础路径"""        name_size_bytes = file_obj.read(4)        if len(name_size_bytes) < 4:            self.BASE_PATH = "../../../"            return self.BASE_PATH                name_size = struct.unpack('<I', name_size_bytes)[0]        if name_size == 0:            self.BASE_PATH = "../../../"            return self.BASE_PATH                base_path = self.read_string(file_obj, name_size)        if name_size != 0x0A and name_size < 0xFF:            self.BASE_PATH = "../../../" + base_path        else:            self.BASE_PATH = base_path                return self.BASE_PATH        def find_magic_offset(self, file_obj):        """查找PAK文件的魔法字节偏移位置"""        file_size = os.path.getsize(file_obj.name)                file_obj.seek(-0x2C, 2)        magic = file_obj.read(4)        version = file_obj.read(4)        file_obj.seek(0)                pattern1 = b"\x2E\x2E\x2F\x2E\x2E\x2F\x2E\x2E\x2F"  # 未加密的"../../../"        pattern2 = b"\x57\x57\x56\x57\x57\x56\x57\x57\x56"  # 加密后的"../../../"                file_obj.seek(0)        data = file_obj.read()                offset1 = data.find(pattern1)        offset2 = data.find(pattern2)                if offset1 != -1:            self.ENCRYPT = 0            return offset1 - 4        elif offset2 != -1:            self.ENCRYPT = 1            return offset2 - 4        else:            file_obj.seek(-0x2C, 2)            return -0x2C        def decrypt_data(self, data):        """异或解密（密钥0x79）"""        if not self.ENCRYPT:            return data                decrypted = bytearray()        for byte in data:            decrypted.append(byte ^ 0x79)        return bytes(decrypted)        def encrypt_data(self, data):        """异或加密（密钥0x79）"""        if not self.ENCRYPT:            return data                encrypted = bytearray()        for byte in data:            encrypted.append(byte ^ 0x79)        return bytes(encrypted)        def read_file_entry(self, file_obj, entry_index):        """读取PAK文件中的文件条目信息"""        entry_start = file_obj.tell()                hash_data = file_obj.read(20)        if len(hash_data) < 20:            return None                entry_data = file_obj.read(49)        if len(entry_data) < 49:            return None                entry = {            'index': entry_index,            'hash': hash_data,            'offset': struct.unpack('<Q', entry_data[0:8])[0],            'size': struct.unpack('<Q', entry_data[8:16])[0],            'zip': struct.unpack('<I', entry_data[16:20])[0],            'zsize': struct.unpack('<Q', entry_data[20:28])[0],            'dummy': entry_data[28:49],            'chunks': [],            'chunk_size': 0x10000,            'encrypted': 0        }                if entry['zip'] != 0:            chunks_data = file_obj.read(4)            if len(chunks_data) >= 4:                try:                    chunk_count = struct.unpack('<I', chunks_data)[0]                    if chunk_count > 1000:                        chunk_count = 1000                                        for _ in range(chunk_count):                        chunk_data = file_obj.read(16)                        if len(chunk_data) >= 16:                            chunk_offset = struct.unpack('<Q', chunk_data[0:8])[0]                            chunk_end = struct.unpack('<Q', chunk_data[8:16])[0]                            entry['chunks'].append((chunk_offset, chunk_end))                except:                    pass                chunk_size_data = file_obj.read(5)        if len(chunk_size_data) >= 5:            try:                entry['chunk_size'] = struct.unpack('<I', chunk_size_data[0:4])[0]                entry['encrypted'] = struct.unpack('B', chunk_size_data[4:5])[0]            except:                entry['chunk_size'] = 0x10000                entry['encrypted'] = 0                if self.ENCRYPT:            file_obj.seek(entry_start)            encrypted_entry = file_obj.read(entry_start - file_obj.tell())            decrypted_entry = self.decrypt_data(encrypted_entry)                        decrypted_file = io.BytesIO(decrypted_entry)            decrypted_file.read(20)            entry_data = decrypted_file.read(49)            entry['offset'] = struct.unpack('<Q', entry_data[0:8])[0]            entry['size'] = struct.unpack('<Q', entry_data[8:16])[0]            entry['zip'] = struct.unpack('<I', entry_data[16:20])[0]            entry['zsize'] = struct.unpack('<Q', entry_data[20:28])[0]                        file_obj.seek(entry_start + len(encrypted_entry))                return entry        def process_directory_structure(self, entries, output_dir, base_path, file_obj):        """处理目录结构并提取文件（修复递归逻辑为迭代）"""        print("开始提取文件...")        toc_file = io.BytesIO(self.TOC_DATA)        processed_files = 0        extracted_files = 0                try:            # 使用循环代替递归            while toc_file.tell() < len(toc_file.getvalue()):                # 读取目录组                dir_count_data = toc_file.read(8)                if len(dir_count_data) < 8:                    break                dir_count = struct.unpack('<Q', dir_count_data)[0]                                # 处理每个目录                for dir_idx in range(dir_count):                    if toc_file.tell() >= len(toc_file.getvalue()):                        break                                        # 读取目录名                    name_size_data = toc_file.read(4)                    if len(name_size_data) < 4:                        break                                        name_size = struct.unpack('<i', name_size_data)[0]                                        if name_size >= 0 and name_size < 1024 * 1024:                        dir_name = self.read_string(toc_file, name_size)                    elif name_size < 0 and abs(name_size) < 1024 * 1024:                        dir_name = self.read_unicode_string(toc_file, abs(name_size))                    else:                        print(f"警告: 无效的目录名长度 {name_size}，跳过")                        # 跳过无效目录，但需要读取目录文件数                        toc_file.read(8)                        continue                                        # 读取目录中的文件数量                    dir_files_data = toc_file.read(8)                    if len(dir_files_data) < 8:                        break                                        dir_files = struct.unpack('<Q', dir_files_data)[0]                                        # 处理目录中的文件                    for file_idx in range(dir_files):                        if toc_file.tell() >= len(toc_file.getvalue()):                            break                                                # 读取文件名                        name_size_data = toc_file.read(4)                        if len(name_size_data) < 4:                            break                                                name_size = struct.unpack('<i', name_size_data)[0]                                                if name_size > 0 and name_size < 1024 * 1024:                            file_name = self.read_string(toc_file, name_size)                        elif name_size < 0 and abs(name_size) < 1024 * 1024:                            file_name = self.read_unicode_string(toc_file, abs(name_size))                        else:                            print(f"警告: 无效的文件名长度 {name_size}，跳过")                            # 跳过无效文件，但需要读取条目索引                            toc_file.read(4)                            continue                                                # 构建完整路径                        full_path = f"{dir_name}{file_name}".replace('//', '/')                        if base_path and base_path != "../../../":                            full_path = f"{base_path}{full_path}".replace('//', '/')                                                # 读取条目索引                        entry_index_data = toc_file.read(4)                        if len(entry_index_data) < 4:                            break                                                entry_index = struct.unpack('<I', entry_index_data)[0]                                                # 提取文件                        if entry_index < len(entries):                            entry = entries[entry_index]                            entry['name'] = full_path                                                        processed_files += 1                            if self.extract_file(file_obj, entry, output_dir):                                self.ENTRIES_DATA[full_path] = {                                  