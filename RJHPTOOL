ck_dir(selection)                if clear_result:                    print_centered_box("✅ 清空完成", [f"已清空解包文件夹: {selection.name}"], "green")                else:                    print_centered_box("❌ 清空失败", ["清空过程中出现错误或用户取消了操作"], "red")            else:                print_centered_box("ℹ️  返回主菜单", ["用户选择了返回"], "blue")            wait_with_extend()                    elif choice == "4":            os.system('clear' if os.name != 'nt' else 'cls')            print_centered_box("⚡ 运行RJH极速提取", ["正在启动RJH程序..."], "cyan")            launch_rjh_program()                    elif choice == "5":            os.system('clear' if os.name != 'nt' else 'cls')            exit_panel = Panel(                Text("感谢使用 RJTOOL PAK 工具", style="cyan") + "\n" +                Text("再见!", style="yellow"),                title=Text("👋 再见", style="bold cyan"),                title_align="center",                style="cyan",                padding=(2, 4)            )            console.print(exit_panel)            break                    else:            print_centered_box("❌ 错误", [                "",                "无效的选择!",                "请输入 1-5 之间的数字",                ""            ], "red")            # 无效选择也用0.45秒默认返回            wait_with_extend()if __name__ == "__main__":    main()