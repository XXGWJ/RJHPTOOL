              if chunk_data_size <= 0:                break                        chunk_data = new_data[data_pos:data_pos+chunk_data_size]            data_chunks.append(chunk_data)            data_pos += chunk_data_size                if len(data_chunks) != len(chunks):            print(f"  ✗ 分块数量不匹配: {len(data_chunks)} != {len(chunks)}")            return False                current_pos = file_obj.tell()        for i, ((chunk_offset, chunk_end), chunk_data) in enumerate(zip(chunks, data_chunks)):            chunk_zsize = chunk_end - chunk_offset            print(f"  处理块 {i}: 最大允许 {chunk_zsize} 字节")                        compressed_chunk = chunk_data            if original_entry['zip'] != 0:                try:                    if len(chunk_data) <= chunk_zsize:                        compressed_chunk = chunk_data                        compressed_size = len(chunk_data)                        print(f"    块 {i} 大小符合要求")                    else:                        best_compressed = None                        best_size = chunk_zsize                                                for level in range(0, 10):                            try:                                compressed = zlib.compress(chunk_data, level=level)                                compressed_size = len(compressed)                                if compressed_size <= chunk_zsize:                                    if best_compressed is None or compressed_size < best_size:                                        best_compressed = compressed                                        best_size = compressed_size                            except:                                continue                                                if best_compressed is None:                            print(f"    ✗ 块 {i} 无法压缩到目标大小")                            file_obj.seek(current_pos)                            return False                                                compressed_chunk = best_compressed                        compressed_size = best_size                                        if compressed_size < chunk_zsize:                        padding = b'\x00' * (chunk_zsize - compressed_size)                        compressed_chunk += padding                except Exception as e:                    print(f"    ⚠ 块 {i} 压缩失败，使用原始数据: {e}")                    if len(chunk_data) > chunk_zsize:                        print(f"    ✗ 块 {i} 数据超过最大大小")                        file_obj.seek(current_pos)                        return False                    compressed_chunk = chunk_data            else:                if len(chunk_data) > chunk_zsize:                    print(f"    ✗ 块 {i} 数据超过最大大小")                    file_obj.seek(current_pos)                    return False                                if len(chunk_data) < chunk_zsize:                    padding = b'\x00' * (chunk_zsize - len(chunk_data))                    compressed_chunk += padding                        if self.ENCRYPT and original_entry['encrypted'] == 1:                compressed_chunk = self.encrypt_data(compressed_chunk)                        file_obj.seek(chunk_offset)            file_obj.write(compressed_chunk)                file_obj.seek(current_pos)        print(f"  ✓ 分块文件替换成功")        return True# ======================== 下半部分：UI界面与主逻辑（最终调整版） ========================from rich.console import Consolefrom rich.panel import Panelfrom rich.table import Tablefrom rich.text import Textimport osimport subprocessfrom pathlib import Pathimport shutilimport timeimport selectimport sysimport ttyimport termios# 初始化 rich 控制台（与上半部分兼容）console = Console()def print_centered_box(title, content_lines=None, color="cyan"):    """模仿 NADEEM 风格的面板打印（基于 rich Panel）"""    title_text = Text(title, style="bold yellow") if title else ""    content = []    if content_lines:        for line in content_lines:            if line.